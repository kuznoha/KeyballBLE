#include "KeyballBLE.dtsi"
/* 入れ替え機能の定義だけを読み込みます */
#include <dt-bindings/zmk/input_transform.h>

&default_transform {
    col-offset = <7>;
};

&kscan0 {
    col-gpios
        = <&xiao_d 10 GPIO_ACTIVE_HIGH>
        , <&xiao_d 9 GPIO_ACTIVE_HIGH> 
        , <&xiao_d 8 GPIO_ACTIVE_HIGH> 
        , <&xiao_d 7 GPIO_ACTIVE_HIGH> 
        , <&gpio0 10 GPIO_ACTIVE_HIGH>
        , <&gpio1 10 GPIO_ACTIVE_HIGH>
        ;
};

/ {
    /* 1. 変換装置の定義（外部ファイルに頼らず直接数値を指定します） */
    xy_transformer: xy_transformer {
        compatible = "zmk,input-processor-transform";
        #input-processor-cells = <1>;
        x-codes = <0x00>; /* INPUT_REL_X の意味 */
        y-codes = <0x01>; /* INPUT_REL_Y の意味 */
    };

    /* 2. トラックボールの動きを処理するリスナー */
    trackball_listener {
        compatible = "zmk,input-listener";
        device = <&trackball>;
        
        /* ↓ ここで上下と左右（XY）を入れ替えます */
        input-processors = <&xy_transformer (INPUT_TRANSFORM_XY_SWAP)>;
    };
};

&pinctrl {
    spi0_default: spi0_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,
                <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                <NRF_PSEL(SPIM_MISO, 0, 4)>;
        };
    };

    spi0_sleep: spi0_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,
                <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                <NRF_PSEL(SPIM_MISO, 0, 4)>;
            low-power-enable;
        };
    };
};

&xiao_serial { status = "disabled"; };

&spi0 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>;

    trackball: trackball@0 {
        status = "okay";
        compatible = "pixart,pmw3610";
        reg = <0>;
        spi-max-frequency = <2000000>;
        
        /* 必須：最新仕様の割り込みピン指定 */
        motion-gpios = <&gpio0 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        
        /* 軸の基本設定（入れ替えは上の listener で行うので 0 と 1 に固定します） */
        zephyr,axis-x = <0>;
        zephyr,axis-y = <1>;
    };
};
